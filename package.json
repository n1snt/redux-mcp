{
  "name": "redux-mcp",
  "version": "0.1.0",
  "description": "redux-mcp lets AI tools (via MCP) and your app connect to Redux state in a simple way.",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./mcp": "./src/mcp/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE.md"
  ],
  "type": "module",
  "private": false,
  "license": "MIT",
  "keywords": [
    "redux",
    "mcp",
    "websocket",
    "bun"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/n1snt/redux-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/n1snt/redux-mcp/issues"
  },
  "homepage": "https://github.com/n1snt/redux-mcp#readme",
  "scripts": {
    "dev:mcp": "bun run src/mcp/index.ts",
    "dev:playground": "bun x vite --config playground/vite.config.ts",
    "build:playground": "bun x vite build --config playground/vite.config.ts",
    "typecheck": "bun x tsc --noEmit && bun x tsc -p playground/tsconfig.json --noEmit",
    "test": "bun x vitest run --coverage",
    "test:publish": "bun x vitest run",
    "test:watch": "bun x vitest",
    "prepublishOnly": "bun run typecheck && bun run test:publish"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "^4.1.4",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@reduxjs/toolkit": "^2.11.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  }
}
