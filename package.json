{
  "name": "redux-mcp",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:mcp": "bun run src/mcp/index.ts",
    "dev:playground": "bun x vite --config playground/vite.config.ts",
    "build:playground": "bun x vite build --config playground/vite.config.ts",
    "typecheck": "bun x tsc --noEmit && bun x tsc -p playground/tsconfig.json --noEmit",
    "test": "bun x vitest run --coverage",
    "test:watch": "bun x vitest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "^4.1.4",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@reduxjs/toolkit": "^2.11.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  }
}
